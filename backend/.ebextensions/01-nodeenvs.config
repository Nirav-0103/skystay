option_settings:
  # Tell EB to use the Procfile command (node server.js)
  aws:elasticbeanstalk:container:nodejs:
    NodeCommand: "node server.js"
    NodeVersion: 20

  # Nginx reverse proxy: forward port 80 → app port
  aws:elasticbeanstalk:environment:proxy:
    ProxyServer: nginx

  # Default env vars (override secrets from EB console, NOT here)
  aws:elasticbeanstalk:application:environment:
    NODE_ENV: production
